{
  "name": "reclaim-toolkit",
  "version": "0.1.0",
  "description": "TypeScript utilities for working with Reclaim.ai APIs",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henss/reclaim-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/henss/reclaim-toolkit/issues"
  },
  "homepage": "https://github.com/henss/reclaim-toolkit#readme",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./cli": {
      "types": "./dist/cli-api.d.ts",
      "import": "./dist/cli-api.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    }
  },
  "bin": {
    "reclaim-toolkit": "dist/cli.js"
  },
  "files": [
    "dist",
    "generated/reclaim-openapi/reclaim-openapi.d.ts",
    "README.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "scripts": {
    "reclaim:help": "tsx src/cli.ts reclaim:help",
    "reclaim:onboarding": "tsx src/cli.ts reclaim:onboarding",
    "reclaim:config:status": "tsx src/cli.ts reclaim:config:status",
    "reclaim:support:bundle": "tsx src/cli.ts reclaim:support:bundle",
    "reclaim:health": "tsx src/cli.ts reclaim:health",
    "reclaim:openapi:capability-matrix": "tsx src/cli.ts reclaim:openapi:capability-matrix",
    "reclaim:time-policies:list": "tsx src/cli.ts reclaim:time-policies:list",
    "reclaim:time-policies:explain-conflicts": "tsx src/cli.ts reclaim:time-policies:explain-conflicts",
    "reclaim:mcp:mock-readonly": "tsx src/cli.ts reclaim:mcp:mock-readonly",
    "reclaim:tasks:preview-create": "tsx src/cli.ts reclaim:tasks:preview-create",
    "reclaim:scenarios:preview-weekly": "tsx src/cli.ts reclaim:scenarios:preview-weekly",
    "reclaim:habits:preview-create": "tsx src/cli.ts reclaim:habits:preview-create",
    "reclaim:focus:preview-create": "tsx src/cli.ts reclaim:focus:preview-create",
    "reclaim:buffers:preview-create": "tsx src/cli.ts reclaim:buffers:preview-create",
    "reclaim:buffers:preview-rule": "tsx src/cli.ts reclaim:buffers:preview-rule",
    "reclaim:buffers:preview-template": "tsx src/cli.ts reclaim:buffers:preview-template",
    "reclaim:meetings:preview-availability": "tsx src/cli.ts reclaim:meetings:preview-availability",
    "reclaim:meetings:preview-recurring-reschedule": "tsx src/cli.ts reclaim:meetings:preview-recurring-reschedule",
    "reclaim:meetings-hours:preview-inspect": "tsx src/cli.ts reclaim:meetings-hours:preview-inspect",
    "reclaim:meetings-hours:preview-switch": "tsx src/cli.ts reclaim:meetings-hours:preview-switch",
    "reclaim:hours-config:preview-audit": "tsx src/cli.ts reclaim:hours-config:preview-audit",
    "reclaim:hours-config:preview-diff": "tsx src/cli.ts reclaim:hours-config:preview-diff",
    "reclaim:account-audit:preview-inspect": "tsx src/cli.ts reclaim:account-audit:preview-inspect",
    "reclaim:account-audit:preview-drift": "tsx src/cli.ts reclaim:account-audit:preview-drift",
    "reclaim:meetings-hours:inspect": "tsx src/cli.ts reclaim:meetings-hours:inspect",
    "reclaim:hours-config:audit": "tsx src/cli.ts reclaim:hours-config:audit",
    "reclaim:account-audit:inspect": "tsx src/cli.ts reclaim:account-audit:inspect",
    "reclaim:demo:mock-api": "tsx src/cli.ts reclaim:demo:mock-api",
    "reclaim:tasks:list": "tsx src/cli.ts reclaim:tasks:list",
    "reclaim:tasks:filter": "tsx src/cli.ts reclaim:tasks:filter",
    "reclaim:tasks:export": "tsx src/cli.ts reclaim:tasks:export",
    "reclaim:tasks:validate-write-receipts": "tsx src/cli.ts reclaim:tasks:validate-write-receipts",
    "reclaim:tasks:create": "tsx src/cli.ts reclaim:tasks:create",
    "reclaim:tasks:inspect-duplicates": "tsx src/cli.ts reclaim:tasks:inspect-duplicates",
    "reclaim:tasks:cleanup-duplicates": "tsx src/cli.ts reclaim:tasks:cleanup-duplicates",
    "reclaim:openapi:prepare-spec": "tsx scripts/generate-openapi-client.ts --prepare-only",
    "reclaim:openapi:generate": "npm run reclaim:openapi:prepare-spec && openapi-typescript generated/reclaim-openapi/reclaim-api-0.1.sanitized.yml -o generated/reclaim-openapi/reclaim-openapi.d.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint:public-boundary": "tsx scripts/lint-public-boundary.ts",
    "git-hooks:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\install-git-hooks.ps1",
    "check:agent-surface": "tsx scripts/check-agent-surface.ts",
    "check:agent-surface:preedit": "tsx scripts/check-agent-surface.ts",
    "check:agent-surface:staged": "tsx scripts/check-agent-surface.ts --staged",
    "refactor:extract-exports": "tsx scripts/refactor-extract-exports.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:typechecked": "eslint . --config eslint.typechecked.config.mjs",
    "verify:session": "npm run lint && npm run typecheck && npm run test && npm run check:agent-surface",
    "arch": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type err",
    "arch:baseline": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --output-type baseline --output-to .dependency-cruiser-known-violations.json",
    "arch:graph": "depcruise . --exclude \"(^|/)(dist|build|coverage|.runtime|.sandbox-tmp)/\" --config .dependency-cruiser.cjs --ignore-known .dependency-cruiser-known-violations.json --output-type mermaid"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.19.0",
    "eslint": "^10.2.0",
    "globals": "^16.5.0",
    "openapi-typescript": "7.13.0",
    "ts-morph": "^27.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^4.1.2",
    "dependency-cruiser": "^17.3.10"
  }
}
